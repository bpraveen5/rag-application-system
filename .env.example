# ============================================================
# RAG Application — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit the actual .env file to version control
# ============================================================

# ── Ollama ────────────────────────────────────────────────────
# Base URL of your Ollama server (use http://ollama:11434 when running via docker-compose)
OLLAMA_BASE_URL=http://localhost:11434
AI_CHAT_MODEL=llama3.2:3b
AI_EMBEDDING_MODEL=nomic-embed-text
# How long Ollama keeps the CHAT model loaded in memory after a request (avoids
# slow reload-from-disk on the next call). Use "-1" to never unload.
# NOT applied to the embedding model — Spring AI has a known bug
# (spring-projects/spring-ai#4619) that breaks embedding calls when keep-alive
# is set, so EmbeddingService intentionally omits it.
AI_CHAT_KEEP_ALIVE=30m
# Max time the app waits for an Ollama chat response before returning a 503.
# CPU-only inference of an 8B model with RAG context can genuinely take several
# minutes; raise this further if you still see LLM_ERROR timeouts.
APP_AI_CALL_TIMEOUT_MS=300000

# Dev mocks: set to true to avoid calling a real Ollama server during local testing
APP_AI_MOCK_EMBEDDINGS=false
APP_AI_MOCK_LLM=false

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=jdbc:postgresql://localhost:5432/ragdb
DATABASE_USERNAME=raguser
DATABASE_PASSWORD=ragpassword

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Security ──────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=your-very-long-and-secure-jwt-secret-key-change-me
JWT_EXPIRATION_MS=86400000
JWT_REFRESH_MS=604800000

# ── Retrieval ─────────────────────────────────────────────────
RETRIEVAL_TOP_K=5
RETRIEVAL_MIN_SIMILARITY=0.7
HYBRID_SEARCH_ENABLED=true
RERANKING_ENABLED=false

# ── Chunking ──────────────────────────────────────────────────
CHUNKING_STRATEGY=recursive
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Conversation ──────────────────────────────────────────────
MAX_HISTORY_MESSAGES=20
CONVERSATION_TTL_HOURS=24

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMITING_ENABLED=true

# ── Server ────────────────────────────────────────────────────
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# ── Monitoring ────────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── Multi-tenancy (optional) ──────────────────────────────────
MULTI_TENANT_ENABLED=false

# ── Document Storage ──────────────────────────────────────────
DOCUMENT_STORAGE_PATH=/tmp/rag-documents
